---
import BaseHead from "@/components/BaseHead.astro";
import Navigation from "@/components/global/Navigation.astro";
import Footer from "@/components/global/Footer.astro";
---

<html lang="en">
  <head>
    <BaseHead />
  </head>
  <body class="flex flex-col min-h-screen bg-white">
    <!-- Full-width green banner -->
    <header class="w-full bg-base-700">
      <div class="max-w-5xl mx-auto px-4 md:px-8 py-4 flex items-center justify-between gap-3 relative">
        <!-- Left: logo + title + tagline -->
        <div class="flex items-center gap-3 md:gap-5 min-w-0">
          <a href="/" class="flex-shrink-0">
            <img
              src="/img/start_image.webp"
              alt="Tech Meditations"
              class="h-12 w-12 md:h-14 md:w-14 rounded-full object-cover"
            />
          </a>
          <div class="flex flex-col gap-0.5 min-w-0">
            <a class="text-xl md:text-2xl font-bold tracking-tight text-white" href="/">Tech Meditations</a>
            <p class="hidden sm:block text-white/60 text-sm">
              My thoughts and discoveries about the evolving tech landscape
            </p>
          </div>
        </div>
        <!-- Right: nav links -->
        <Navigation />
      </div>
    </header>

    <main class="flex-grow max-w-5xl w-full mx-auto px-8">
      <slot />
    </main>

    <Footer />

    <!-- Search modal -->
    <div
      x-data="{ open: false }"
      @open-search.window="open = true; $nextTick(() => document.querySelector('.pagefind-ui__search-input')?.focus())"
      @keydown.escape.window="open = false"
    >
      <div x-cloak x-show="open" class="fixed inset-0 z-50 flex items-start justify-center pt-24 px-4">
        <div class="absolute inset-0 bg-black/60" @click="open = false"></div>
        <div class="relative w-full max-w-2xl bg-white rounded-xl shadow-2xl p-6">
          <div id="search"></div>
        </div>
      </div>
    </div>

    <link href="/pagefind/pagefind-ui.css" rel="stylesheet" />
    <script src="/pagefind/pagefind-ui.js" is:inline></script>
    <script>
      new PagefindUI({ element: "#search", showImages: false, resetStyles: false });
    </script>
  </body>
</html>
