---
import { Image } from "astro:assets";
const { title, url, description, pubDate, author, image, tags } = Astro.props;
---

<article class="flex items-stretch gap-0 rounded-xl overflow-hidden bg-base-50 hover:bg-base-100 transition-colors duration-200">
  <!-- Square image on the left -->
  <a href={url} class="flex-shrink-0 block w-32">
    <Image
      width={400}
      height={400}
      src={image}
      alt={title}
      class="object-cover w-full h-full"
    />
  </a>

  <!-- Content on the right -->
  <div class="flex flex-col justify-center px-8 py-3 gap-1.5">
    <h3 class="text-xl font-bold text-base-900">
      <a href={url} class="hover:underline">{title}</a>
    </h3>
    <p class="text-sm text-base-900 leading-relaxed">{description}</p>
    <div class="flex items-center gap-2 mt-1 text-xs font-semibold tracking-widest uppercase text-base-900">
      <span>{pubDate}</span>
      <span class="text-base-300">·</span>
      <span>{tags.join(" · ")}</span>
    </div>
  </div>
</article>
